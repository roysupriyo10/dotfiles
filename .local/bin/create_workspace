#!/bin/zsh

# Number of windows per session
WINDOWS=2

alias tmux="/opt/homebrew/bin/tmux"

# Function to create tmux session and windows
function create_tmux_session() {
    local session_name=$1
    local session_path=$2
    
    # Create session if it doesn't exist
    if ! tmux has-session -t "$session_name" 2>/dev/null; then
        tmux new-session -d -s "$session_name" -c "$session_path"
        
        # Create additional windows
        for ((i=1; i<=$WINDOWS; i++)); do
            tmux new-window -t "$session_name" -c "$session_path"
        done
    fi
}

# Backend sessions
sessions=(
    "backend/root:/Users/rs10figr/developer/backend"
    "backend/uml:/Users/rs10figr/developer/backend/uml"
    "backend/auth:/Users/rs10figr/developer/backend/apps/authentication"
    "backend/db:/Users/rs10figr/developer/backend/packages/db"
)

# Create all sessions
for session in $sessions; do
    name=${session%%:*}   # Get part before :
    path=${session#*:}    # Get part after :
    create_tmux_session $name $path
done

# Function to kill all backend sessions
kill_backend() {
    for session in $(tmux list-sessions -F "#{session_name}" 2>/dev/null); do
        if [[ $session == backend* ]]; then
            tmux kill-session -t "$session"
            echo "Killed session: $session"
        fi
    done
}

# Select first session and attach
tmux select-window -t "${sessions[1]%%:*}:0"
tmux attach-session -t "${sessions[1]%%:*}"
