#!/usr/bin/env bash
# Stage clipboard image under git-root/.cursor/clip/ (works local or over kitten ssh).
set -euo pipefail

. "$(dirname "$0")/clip-common.sh"

if ! command -v kitten >/dev/null 2>&1; then
  printf 'clip-stage: kitten not found (use kitty / kitten ssh)\n' >&2
  exit 1
fi

root=$(clip_git_root)
out=$(clip_path_under_root "$root" "${1:-clip.png}")
kitten clipboard -g "$out"
printf '%s\n' "$out"
