#!/bin/bash

NUM_WINDOWS=3

tmux new-session -d -s "crackadeal-server" -c "/home/roysupriyo10/developer/typescript/crackadeal/server"
tmux new-session -d -s "crackadeal-client" -c "/home/roysupriyo10/developer/typescript/crackadeal/client"
tmux new-session -d -s "crackadeal-admin" -c "/home/roysupriyo10/developer/typescript/crackadeal/admin"
tmux new-session -d -s "mongosh" -c "/home/roysupriyo10/developer/typescript/crackadeal/server"

for ((j=1; j<=2; j++)); do
  tmux new-window -d -t "crackadeal-server" -c "/home/roysupriyo10/developer/typescript/crackadeal/server"
  tmux new-window -d -t "crackadeal-client" -c "/home/roysupriyo10/developer/typescript/crackadeal/client"
  tmux new-window -d -t "crackadeal-admin" -c "/home/roysupriyo10/developer/typescript/crackadeal/admin"
done

tmux a
