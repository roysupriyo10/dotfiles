#!/usr/bin/env bash
# Paste clipboard image into the active kitty terminal (Cursor agent CLI, Claude Code).
# GUI apps (Cursor desktop, etc.) — use VNC and paste there directly.
# Image paste is always Ctrl+V.
set -euo pipefail

paste_via_kitty() {
  command -v kitten >/dev/null 2>&1 || return 1
  kitten @ send-key ctrl+v 2>/dev/null
}

paste_ctrl_v_linux() {
  command -v ydotool >/dev/null 2>&1 || {
    printf 'agent-chat-paste: ydotool required on Linux (see install/toolchain)\n' >&2
    exit 1
  }
  ydotool key 29:1 47:1 47:0 29:0
}

paste_ctrl_v_macos() {
  osascript -e 'tell application "System Events" to keystroke "v" using control down'
}

if paste_via_kitty; then
  exit 0
fi

case "$(uname)" in
  Linux) paste_ctrl_v_linux ;;
  Darwin) paste_ctrl_v_macos ;;
  *)
    printf 'agent-chat-paste: unsupported OS: %s\n' "$(uname)" >&2
    exit 1
    ;;
esac
