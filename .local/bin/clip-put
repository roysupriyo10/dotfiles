#!/usr/bin/env bash
# Push file(s) → local kitty clipboard (over kitten ssh or local kitty).
set -euo pipefail

if [ "$#" -lt 1 ]; then
  printf 'usage: clip-put <file> [file ...]\n' >&2
  exit 1
fi

if ! command -v kitten >/dev/null 2>&1; then
  printf 'clip-put: kitten not found (use kitty / kitten ssh)\n' >&2
  exit 1
fi

kitten clipboard "$@"
