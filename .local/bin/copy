#!/bin/bash

# Check if required commands are available
for cmd in pv stat; do
    if ! command -v $cmd &> /dev/null; then
        echo "Error: Required command '$cmd' not found. Please install it first."
        echo "On Debian/Ubuntu: sudo apt-get install $cmd"
        echo "On CentOS/RHEL: sudo yum install $cmd"
        exit 1
    fi
done

# Check if correct number of arguments provided
if [ "$#" -ne 2 ]; then
    echo "Usage: $0 source_file destination"
    echo "Example: $0 largefile.iso /media/backup/"
    exit 1
fi

source="$1"
dest="$2"

# Check if source file exists
if [ ! -f "$source" ]; then
    echo "Error: Source file '$source' does not exist"
    exit 1
fi

# If destination is a directory, append the source filename
if [ -d "$dest" ]; then
    dest="$dest/$(basename "$source")"
fi

# Check if we have read access to source and write access to destination directory
if [ ! -r "$source" ]; then
    echo "Error: No read permission for '$source'"
    exit 1
fi

if [ ! -w "$(dirname "$dest")" ]; then
    echo "Error: No write permission for destination directory '$(dirname "$dest")'"
    exit 1
fi

# Get file size - handle both Linux and macOS stat formats
if [[ "$OSTYPE" == "darwin"* ]]; then
    # macOS
    size=$(stat -f%z "$source")
else
    # Linux
    size=$(stat -c%s "$source")
fi

if [ $? -ne 0 ]; then
    echo "Error: Unable to determine file size"
    exit 1
fi

# Perform the copy with progress bar
pv -s "$size" "$source" > "$dest"

# Verify the copy was successful
if [ $? -eq 0 ]; then
    echo "Copy completed successfully"
else
    echo "Error occurred during copy"
    rm -f "$dest"  # Clean up partial file
    exit 1
fi
