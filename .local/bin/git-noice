#!/bin/bash

# Check if all arguments are provided
if [ "$#" -ne 3 ]; then
  echo "Usage: $0 <main-branch> <merge-into-branch> <commit-message>"
  exit 1
fi

MAIN_BRANCH=$1
MERGE_INTO_BRANCH=$2
COMMIT_MESSAGE=$3

if [ $MAIN_BRANCH != "master" ]; then
  echo "main branch must be master"
  exit 1
fi

# Add all changes
git add -A

# Commit with provided message
git commit -m "$COMMIT_MESSAGE"

# Push to main branch
git push origin "$MAIN_BRANCH"

# Checkout merge-into branch
git checkout "$MERGE_INTO_BRANCH"

# Merge main branch into merge-into branch
git merge "$MAIN_BRANCH"

# Push to merge-into branch
git push origin "$MERGE_INTO_BRANCH"

# Checkout main branch
git checkout "$MAIN_BRANCH"

echo "Process complete."

