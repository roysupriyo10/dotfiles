#!/bin/bash

NUM_WINDOWS=3

tmux new-session -ds "comp-server" -c "/home/roysupriyo10/developer/compareling/server"
tmux new-session -ds "comp-admin-client" -c "/home/roysupriyo10/developer/compareling/admin-client"
tmux new-session -ds "comp-agency-client" -c "/home/roysupriyo10/developer/compareling/agency-client"
tmux new-session -ds "comp-user-client" -c "/home/roysupriyo10/developer/compareling/user-client"
tmux new-session -ds "comp-file-server" -c "/home/roysupriyo10/developer/compareling/file-server"
for ((j=1; j<=2; j++)); do
  tmux new-window -dt "comp-server" -c "/home/roysupriyo10/developer/compareling/server"
  tmux new-window -dt "comp-admin-client" -c "/home/roysupriyo10/developer/compareling/admin-client"
  tmux new-window -dt "comp-agency-client" -c "/home/roysupriyo10/developer/compareling/agency-client"
  tmux new-window -dt "comp-user-client" -c "/home/roysupriyo10/developer/compareling/user-client"
  tmux new-window -dt "comp-file-server" -c "/home/roysupriyo10/developer/compareling/file-server"
done

tmux a
