#!/usr/bin/env bash
# Kitty hotkey: stage local clipboard → file, @attach into agent (local or kitten ssh).
set -euo pipefail

run_in_active_window() {
  command -v kitten >/dev/null 2>&1 || return 1
  kitten @ send-text --match active-window $'p=$(clip-stage) && agent-chat-paste "$p"\n' 2>/dev/null
}

if run_in_active_window; then
  exit 0
fi

p=$(clip-stage)
agent-chat-paste "$p"
