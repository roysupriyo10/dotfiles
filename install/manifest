# Symlinks: LINK <repo-path> <dest-path>
# Mirrors:  MIRROR <repo-dir> <dest-dir>
# Hooks:    HOOK <name>
# Prefix LINUX or DARWIN for platform-only entries.
# Dest paths: always ${HOME}/... (never ~)
#
# Failure policy:
#   HARD — abort install: unknown CLI flags, missing lndir
#   SOFT — skip entry: submodule-deps not ready (logged), missing mirror src dir

LINK .zshrc ${HOME}/.zshrc
LINK .bashrc ${HOME}/.bashrc

LINK kitty ${HOME}/.config/kitty
LINK lsd ${HOME}/.config/lsd
LINK tmux ${HOME}/.config/tmux
LINK nvim ${HOME}/.config/nvim
MIRROR .local/bin ${HOME}/.local/bin

LINUX LINK .zprofile ${HOME}/.zprofile
LINUX LINK sway ${HOME}/.config/sway
LINUX LINK mako ${HOME}/.config/mako
LINUX LINK fontconfig ${HOME}/.config/fontconfig
LINUX LINK environment.d ${HOME}/.config/environment.d
LINUX LINK wireplumber ${HOME}/.config/wireplumber
LINUX LINK foot ${HOME}/.config/foot
LINUX LINK imv ${HOME}/.config/imv
LINUX LINK systemd/user ${HOME}/.config/systemd/user

DARWIN LINK aerospace ${HOME}/.config/aerospace
DARWIN HOOK darwin-keymap

HOOK cursor
HOOK claude
HOOK agy
